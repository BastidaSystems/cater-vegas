# Public Supabase values used by the static frontend.
# These are safe to expose as browser config when RLS is enabled.
CATER_VEGAS_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
CATER_VEGAS_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
CATER_VEGAS_WORKSPACE_ID=cater-vegas

# Supabase Edge Function secrets.
# Set these with: supabase secrets set OPENAI_API_KEY=... SUPABASE_SERVICE_ROLE_KEY=...
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4.1-mini
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional bridge from Cater Vegas into the BEOFlow client brain.
# BEOFLOW_SERVICE_ROLE_KEY must be the BEOFlow Supabase service role key, never the anon key.
BEOFLOW_SUPABASE_URL=https://YOUR_BEOFLOW_PROJECT_ID.supabase.co
BEOFLOW_SERVICE_ROLE_KEY=YOUR_BEOFLOW_SERVICE_ROLE_KEY
BEOFLOW_CLIENT_NAME=Cater Vegas
